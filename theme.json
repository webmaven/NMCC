{
    "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                {
                    "color": "#FAF8F5",
                    "name": "Soft Cream",
                    "slug": "soft-cream"
                },
                {
                    "color": "#EFECE6",
                    "name": "Warm Alabaster",
                    "slug": "warm-alabaster"
                },
                {
                    "color": "#2E2C29",
                    "name": "Warm Charcoal",
                    "slug": "warm-charcoal"
                },
                {
                    "color": "#66625C",
                    "name": "Warm Charcoal Muted",
                    "slug": "warm-charcoal-muted"
                },
                {
                    "color": "#C85A32",
                    "name": "Clay Accent",
                    "slug": "clay"
                },
                {
                    "color": "#708A77",
                    "name": "Sage Secondary",
                    "slug": "sage"
                },
                {
                    "color": "#FFFFFF",
                    "name": "White",
                    "slug": "white"
                }
            ],
            "custom": false,
            "customGradient": false,
            "gradients": [],
            "link": true,
            "defaultPalette": false,
            "defaultGradients": false
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "\"Noto Serif\", \"Noto Serif Cherokee\", Georgia, serif",
                    "name": "Noto Serif (English & Cherokee)",
                    "slug": "noto-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Noto Serif",
                            "fontStyle": "normal",
                            "fontWeight": "400",
                            "src": [
                                "file:./assets/fonts/NotoSerif-Regular.woff2",
                                "https://fonts.gstatic.com/s/notoserif/v23/ga6iax7q_JCvSD_898F_vKAn_28.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Noto Serif",
                            "fontStyle": "italic",
                            "fontWeight": "400",
                            "src": [
                                "file:./assets/fonts/NotoSerif-Italic.woff2",
                                "https://fonts.gstatic.com/s/notoserif/v23/ga6kax7q_JCvSD_898F_vKAn_3O9aM4.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Noto Serif",
                            "fontStyle": "normal",
                            "fontWeight": "600",
                            "src": [
                                "file:./assets/fonts/NotoSerif-SemiBold.woff2",
                                "https://fonts.gstatic.com/s/notoserif/v23/ga6lax7q_JCvSD_898F_vKAn_28.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Noto Serif Cherokee",
                            "fontStyle": "normal",
                            "fontWeight": "400 700",
                            "src": [
                                "file:./assets/fonts/NotoSerifCherokee-VariableFont_wght.ttf",
                                "https://fonts.gstatic.com/s/notoserifcherokee/v23/g600rkOCb8Jv1e5fI9GdrhZ6VlI-2Uv7W_k.woff2"
                            ]
                        }
                    ]
                },
                {
                    "fontFamily": "\"Noto Sans\", \"Noto Sans Cherokee\", system-ui, -apple-system, sans-serif",
                    "name": "Noto Sans (English & Cherokee)",
                    "slug": "noto-sans",
                    "fontFace": [
                        {
                            "fontFamily": "Noto Sans",
                            "fontStyle": "normal",
                            "fontWeight": "400",
                            "src": [
                                "file:./assets/fonts/NotoSans-Regular.woff2",
                                "https://fonts.gstatic.com/s/notosans/v36/o-0IIpQlx3QUlC5A4PNr5TRA.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Noto Sans",
                            "fontStyle": "normal",
                            "fontWeight": "600",
                            "src": [
                                "file:./assets/fonts/NotoSans-SemiBold.woff2",
                                "https://fonts.gstatic.com/s/notosans/v36/o-0NIpQlx3QUlC5A4PNjXhFVZs9B.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Noto Sans Cherokee",
                            "fontStyle": "normal",
                            "fontWeight": "400 700",
                            "src": [
                                "file:./assets/fonts/NotoSansCherokee-VariableFont_wght.ttf",
                                "https://fonts.gstatic.com/s/notosanscherokee/v24/g60_rkOCb8Jv1e5fI9GdrhZ6VlI-2Uv7W_k.woff2"
                            ]
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "size": "0.875rem",
                    "name": "Small",
                    "slug": "small"
                },
                {
                    "size": "1rem",
                    "name": "Medium",
                    "slug": "medium"
                },
                {
                    "size": "1.25rem",
                    "name": "Large",
                    "slug": "large"
                },
                {
                    "size": "1.5rem",
                    "name": "Extra Large",
                    "slug": "x-large"
                },
                {
                    "size": "2rem",
                    "name": "Double Extra Large",
                    "slug": "xx-large"
                },
                {
                    "size": "2.75rem",
                    "name": "Triple Extra Large",
                    "slug": "xxx-large"
                }
            ],
            "customFontSize": false,
            "lineHeight": true
        },
        "layout": {
            "contentSize": "680px",
            "wideSize": "1100px"
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--soft-cream)",
            "text": "var(--wp--preset--color--warm-charcoal)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--noto-sans)",
            "fontSize": "1rem",
            "lineHeight": "1.65"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--noto-serif)",
                    "fontWeight": "600",
                    "lineHeight": "1.25"
                },
                "color": {
                    "text": "var(--wp--preset--color--warm-charcoal)"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xxx-large)"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xx-large)",
                    "letterSpacing": "-0.01em"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--x-large)"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--large)"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--clay)"
                },
                "typography": {
                    "textDecoration": "underline"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--sage)"
                    }
                }
            },
            "button": {
                "color": {
                    "text": "var(--wp--preset--color--white)",
                    "background": "var(--wp--preset--color--clay)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--noto-sans)",
                    "fontWeight": "600",
                    "textDecoration": "none",
                    "fontSize": "1rem"
                },
                "border": {
                    "radius": "8px"
                },
                "spacing": {
                    "padding": {
                        "top": "0.75rem",
                        "bottom": "0.75rem",
                        "left": "1.5rem",
                        "right": "1.5rem"
                    }
                }
            }
        },
        "blocks": {
            "core/post-title": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--noto-serif)",
                    "fontWeight": "600",
                    "lineHeight": "1.15"
                },
                "color": {
                    "text": "var(--wp--preset--color--warm-charcoal)"
                }
            },
            "core/post-excerpt": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--medium)"
                },
                "color": {
                    "text": "var(--wp--preset--color--warm-charcoal-muted)"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontWeight": "600",
                    "fontSize": "0.95rem"
                }
            }
        }
    }
}
